# ── ShopSense AI Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values

# Google Gemini API key from aistudio.google.com (free tier available)
GEMINI_API_KEY=AIzaSyCdxTfuu5fAaTzvgoYBIzBwnFrTYcLCz14

# Gemini model to use (gemini-2.0-flash is free and fast)
GEMINI_MODEL=gemini-2.0-flash

# Allowed extension origins (comma-separated)
# The Chrome extension ID changes per browser profile during development.
# Set to * during development, restrict in production.
ALLOWED_ORIGINS=*

# Optional: Redis URL for shared cache (leave blank for in-memory cache)
REDIS_URL=

# Port for local development
PORT=8000
