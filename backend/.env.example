# ── ShopSense AI Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values

# Groq API key from console.groq.com (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (llama-3.3-70b-versatile is free and fast)
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Allowed extension origins (comma-separated)
# The Chrome extension ID changes per browser profile during development.
# Set to * during development, restrict in production.
ALLOWED_ORIGINS=*

# Optional: HMAC shared secret for request signing (leave blank to disable)
# If set, the extension must send X-Signature + X-Timestamp headers.
API_SECRET_KEY=

# Optional: Redis URL for shared cache (leave blank for in-memory cache)
REDIS_URL=

# Port for local development
PORT=8000
